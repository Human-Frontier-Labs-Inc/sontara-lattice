# Sontara Lattice — environment variables
# Copy to .env and fill in values before running docker-compose up.

# NATS auth token (optional — leave blank for unauthenticated local NATS)
NATS_TOKEN=

# LLM endpoint for daemon workflows (supervisor, response-daemon)
# Point this at an OpenAI-compatible proxy (LiteLLM, etc.)
LLM_BASE_URL=http://host.docker.internal:4000/v1
LLM_MODEL=vertex_ai/claude-sonnet-4-6
LLM_API_KEY=
