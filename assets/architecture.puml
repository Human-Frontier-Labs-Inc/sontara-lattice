@startuml architecture
skinparam backgroundColor white
skinparam defaultFontName monospaced
skinparam shadowing false
skinparam roundCorner 6
skinparam ArrowColor #444
skinparam NodeBackgroundColor #f8f8f8
skinparam NodeBorderColor #ccc
skinparam QueueBackgroundColor #e8f4e8
skinparam QueueBorderColor #aaa
skinparam CloudBackgroundColor #f0f4ff
skinparam CloudBorderColor #aaa

title claude-peers: Fleet Architecture

together {
  node "workstation" as om
  node "macbook" as mb
  node "laptop" as tb
}

node "broker-host" as homelab {
  [Broker] as broker
  queue "NATS" as nats
  [Supervisor] as super
}

cloud "LiteLLM" as llm

node "edge-device" as rp {
  [Gridwatch] as gw
}

node "iot-device" as v4 {
  [Ghostbox] as ghost
}

om --> broker : Claude sessions\n(MCP + messages)
mb --> broker
tb --> broker

broker <-> nats : events

super --> nats : daemon results
super ..> llm : triage.sh -> agent\n(Haiku / Sonnet)

gw --> broker : peers + events
gw --> nats : ticker events
gw --> homelab : SSH + HTTP\n(service monitoring)

ghost --> nats : subscribe\n(critical = alarm)

note bottom of super
  6 daemons with triage:
  triage.sh (free) -> agent (LLM)
  skip if no work needed
end note

note right of gw
  4-page kiosk dashboard
  Fleet | Services | NATS | Agents
  Live scrolling ticker
end note
@enduml
