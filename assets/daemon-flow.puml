@startuml daemon-flow
skinparam backgroundColor white
skinparam defaultFontName monospaced
skinparam shadowing false
skinparam ArrowColor #444
skinparam ActivityBackgroundColor #f8f8f8
skinparam ActivityBorderColor #ccc

title Daemon Lifecycle: Triage -> Execute -> Publish

start

:Schedule fires\n(interval or NATS event);

if (Already running?) then (yes)
  :skip;
  stop
endif

if (Failed recently?) then (yes, <5min)
  :cooldown skip;
  stop
endif

if (triage.sh exists?) then (yes)
  :Run **triage.sh**\n(bash, zero cost);
  if (exit code?) then (exit 1)
    :No work needed\n**skip** (free);
    :Publish triage_skip\nto NATS;
    stop
  else (exit 0)
    :Work found;
  endif
endif

:Run **agent**\n(Haiku/Sonnet via LiteLLM);

if (Agent result?) then (success)
  :Extract output from\nJSON envelope;
  :Publish **daemon_complete**\nto NATS;
else (failure)
  :Set 5min cooldown;
  :Publish **daemon_failed**\nto NATS;
endif

:Gridwatch ticker\npicks up event;

:Dashboard shows\ndaemon output;

stop

@enduml
